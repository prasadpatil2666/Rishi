@page "/"
@using StayFocus.Models

<!-- NAV -->
<nav class="navbar">
    <div class="nav-container">
        <a href="/" class="navbar-brand">
            <span class="brand-icon">✓</span>
            <span class="brand-text">View<span class="brand-highlight">dly</span></span>
        </a>
        <div class="nav-links">
            <a href="#reviews" class="nav-link">Reviews</a>
            <a href="#how" class="nav-link">How it works</a>
            <a href="#" class="nav-link nav-cta">Sign In</a>
        </div>
    </div>
</nav>

<main class="main-content-wrapper">

<!-- HERO & SEARCH SECTION -->
<section class="hero-search">
    <div class="hero-gradient"></div>
    <div class="hero-content">
        <div class="hero-badge">
            <span class="badge-icon">⭐</span>
            Join 10,000+ reviewers demanding trust
        </div>
        <h1 class="hero-title">Reviews You Can <span class="highlight">Actually Trust</span></h1>
        <p class="hero-subtitle">
            Verified purchases. Real video proof. Brands must respond. 
            <br />No fake stars. No bots. Just honest experiences.
        </p>

        <!-- Massive Search Bar -->
        <div class="search-container">
            <div class="search-wrapper">
                <span class="search-icon">🔍</span>
                <input 
                    type="text" 
                    class="massive-search-input" 
                    placeholder="Search companies, products, or services..."
                    @bind="searchQuery"
                    @oninput="OnSearchInput"
                    @onkeyup="HandleKeyUp"
                />
                <button class="search-button" @onclick="PerformSearch">Search</button>
            </div>

            <!-- Category Filter Section -->
            <div class="filter-section">
                <label class="filter-label">Filter by Category (Optional)</label>
                <div class="category-buttons">
                    @foreach (var category in categories)
                    {
                        <button 
                            class="category-btn @(selectedCategory == category ? "active" : "")"
                            @onclick="() => SelectCategory(category)"
                        >
                            <span class="cat-icon">@GetCategoryIcon(category)</span>
                            <span>@category</span>
                        </button>
                    }
                    @if (!string.IsNullOrEmpty(selectedCategory))
                    {
                        <button 
                            class="category-btn clear-btn"
                            @onclick="() => ClearCategory()"
                        >
                            <span>✕</span>
                        </button>
                    }
                </div>
            </div>

            <!-- Common Searches -->
            <div class="common-searches">
                <p class="common-label">Popular searches:</p>
                <div class="search-chips">
                    @foreach (var search in GetCommonSearches().Take(4))
                    {
                        <button class="search-chip" @onclick="() => QuickSearch(search)">
                            @search
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- REVIEWS SECTION -->
<section class="reviews-section" id="reviews">
    <div class="container">
        <div class="reviews-grid">
            <!-- Reviews Feed -->
            <div class="reviews-feed">
                <div class="feed-header">
                    <h2>@(string.IsNullOrEmpty(searchQuery) ? "Latest Reviews" : $"Search Results for \"{searchQuery}\"")</h2>
                    @if (!string.IsNullOrEmpty(selectedCategory))
                    {
                        <span class="active-filter">@GetCategoryIcon(selectedCategory) @selectedCategory</span>
                    }
                </div>

                @if (filteredReviews.Any())
                {
                    <div class="reviews-list">
                        @foreach (var review in filteredReviews)
                        {
                            <ReviewCard Review="review" />
                        }
                    </div>
                }
                else if (hasSearched)
                {
                    <div class="no-results-state">
                        <div class="no-results-icon">🔍</div>
                        <h3>No reviews found</h3>
                        <p>Be the first to share your experience with @(string.IsNullOrEmpty(searchQuery) ? "this product" : searchQuery)</p>
                        <button class="btn-primary">Write a Review</button>
                    </div>
                }
                else
                {
                    <div class="placeholder-state">
                        <div class="placeholder-icon">📱</div>
                        <p>Start searching to discover verified reviews</p>
                    </div>
                }
            </div>

            <!-- Sidebar -->
            <aside class="sidebar">
                <!-- Request Help Widget -->
                <div class="widget request-help-widget">
                    <div class="widget-icon">📞</div>
                    <h3>Bad Experience?</h3>
                    <p>Our mediation team helps you get fair resolutions.</p>
                    <button class="btn-request-help" @onclick="ShowRequestHelp">
                        Request Mediation
                    </button>
                </div>

                <!-- Stats Widget -->
                <div class="widget stats-widget">
                    <h3>Community Stats</h3>
                    <div class="stat-item">
                        <div class="stat-number">@reviews.Count</div>
                        <div class="stat-label">Total Reviews</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">@(reviews.Count(r => r.IsVerified))</div>
                        <div class="stat-label">Verified Reviews</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">@reviews.Average(r => r.Rating).ToString("0.0")</div>
                        <div class="stat-label">Average Rating</div>
                    </div>
                </div>

                <!-- Why Trust Viewdly -->
                <div class="widget trust-widget">
                    <h3>Why Trust Viewdly?</h3>
                    <ul class="trust-features">
                        <li><span>✓</span> Verified purchases only</li>
                        <li><span>✓</span> Video proof required</li>
                        <li><span>✓</span> No fake reviews</li>
                        <li><span>✓</span> Brands must respond</li>
                    </ul>
                </div>
            </aside>
        </div>
    </div>
</section>

<!-- HOW IT WORKS SECTION -->
<section class="how-section" id="how">
    <div class="container">
        <h2 class="section-title">How Viewdly Works</h2>
        <div class="how-grid">
            <div class="how-card">
                <div class="how-step">1</div>
                <div class="how-icon">🛍️</div>
                <h3>Verify Purchase</h3>
                <p>Connect your email or upload your receipt. Only verified owners get the badge.</p>
            </div>
            <div class="how-card">
                <div class="how-step">2</div>
                <div class="how-icon">🎥</div>
                <h3>Add Video Proof</h3>
                <p>Quick 15-30 second video of the product. Real unboxing is worth a thousand words.</p>
            </div>
            <div class="how-card">
                <div class="how-step">3</div>
                <div class="how-icon">⭐</div>
                <h3>Rate & Review</h3>
                <p>Share your honest experience with detailed ratings and authentic feedback.</p>
            </div>
            <div class="how-card">
                <div class="how-step">4</div>
                <div class="how-icon">🤝</div>
                <h3>Brands Respond</h3>
                <p>Companies earn a Resolution Score by actually fixing problems. Publicly visible forever.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA SECTION -->
<section class="cta-section">
    <div class="cta-content">
        <h2>Ready to Share Your Truth?</h2>
        <p>Join thousands of honest reviewers shaping a trustworthy internet.</p>
        <button class="btn-primary btn-large">Start Reviewing Now</button>
    </div>
</section>

<!-- Request Help Modal -->
@if (showRequestHelpModal)
{
    <RequestHelpModal OnClose="CloseRequestHelp" />
}

</main>

@code {
    private string searchQuery = "";
    private string selectedCategory = "";
    private bool showRequestHelpModal = false;
    private bool hasSearched = false;

    private List<string> categories = new()
    {
        "Company Reviews",
        "Mobile Devices",
        "Technology",
        "Services",
        "Retail",
        "Restaurants",
        "Travel"
    };

    private List<Review> reviews = new();
    private List<Review> filteredReviews = new();

    protected override void OnInitialized()
    {
        // Initialize sample data
        reviews = new()
        {
            new Review 
            { 
                Id = 1,
                CompanyName = "Microsoft",
                Category = "Company Reviews",
                Rating = 4.5m,
                Title = "Excellent workplace culture",
                Content = "Great benefits and amazing team members. The work environment is very collaborative and supportive.",
                Location = "Seattle, WA",
                IsVerified = true,
                Author = "John D.",
                Date = DateTime.Now.AddDays(-5),
                HelpfulCount = 245
            },
            new Review 
            { 
                Id = 2,
                CompanyName = "Apple iPhone 15 Pro Max",
                Category = "Mobile Devices",
                Rating = 5m,
                Title = "Best smartphone I've ever owned",
                Content = "Amazing camera quality with exceptional low-light performance. Battery life easily lasts the whole day. Performance is snappy with the A17 Pro. Highly recommended!",
                Location = "San Francisco, CA",
                IsVerified = true,
                Author = "Sarah M.",
                Date = DateTime.Now.AddDays(-2),
                HelpfulCount = 512
            },
            new Review 
            { 
                Id = 3,
                CompanyName = "Google",
                Category = "Company Reviews",
                Rating = 4m,
                Title = "Good company, competitive salary",
                Content = "Solid work environment with excellent perks. Some bureaucracy in decision making slows things down.",
                Location = "Mountain View, CA",
                IsVerified = true,
                Author = "Mike P.",
                Date = DateTime.Now.AddDays(-8),
                HelpfulCount = 189
            },
            new Review 
            { 
                Id = 4,
                CompanyName = "Samsung Galaxy S24",
                Category = "Mobile Devices",
                Rating = 4.5m,
                Title = "Solid Android phone",
                Content = "Great display with vibrant colors. Performance is excellent. Battery could be better, but overall satisfied.",
                Location = "Seoul, South Korea",
                IsVerified = true,
                Author = "Alex K.",
                Date = DateTime.Now.AddDays(-1),
                HelpfulCount = 156
            },
            new Review 
            { 
                Id = 5,
                CompanyName = "Starbucks",
                Category = "Restaurants",
                Rating = 3.5m,
                Title = "Good coffee but overpriced",
                Content = "Coffee quality is decent, staff is usually friendly. However, prices are quite high for what you get.",
                Location = "New York, NY",
                IsVerified = true,
                Author = "Emma R.",
                Date = DateTime.Now.AddDays(-3),
                HelpfulCount = 89
            },
            new Review 
            { 
                Id = 6,
                CompanyName = "MacBook Pro 14",
                Category = "Technology",
                Rating = 5m,
                Title = "Perfect for development",
                Content = "The M3 Pro is incredibly fast. Perfect for coding, design, and video editing. Build quality is top-notch.",
                Location = "Austin, TX",
                IsVerified = true,
                Author = "Dev J.",
                Date = DateTime.Now.AddDays(-7),
                HelpfulCount = 423
            }
        };

        filteredReviews = reviews;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? "";
        PerformSearch();
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            PerformSearch();
        }
    }

    private void PerformSearch()
    {
        hasSearched = true;
        var query = searchQuery.ToLower();

        filteredReviews = reviews
            .Where(r => 
                (string.IsNullOrEmpty(query) || 
                 r.CompanyName.ToLower().Contains(query) ||
                 r.Title.ToLower().Contains(query) ||
                 r.Content.ToLower().Contains(query) ||
                 r.Location.ToLower().Contains(query)) &&
                (string.IsNullOrEmpty(selectedCategory) || r.Category == selectedCategory)
            )
            .OrderByDescending(r => r.Date)
            .ToList();
    }

    private void SelectCategory(string category)
    {
        selectedCategory = category;
        PerformSearch();
    }

    private void ClearCategory()
    {
        selectedCategory = "";
        PerformSearch();
    }

    private void QuickSearch(string searchTerm)
    {
        searchQuery = searchTerm;
        PerformSearch();
    }

    private List<string> GetCommonSearches()
    {
        return selectedCategory switch
        {
            "Company Reviews" => new() { "Microsoft", "Google", "Amazon", "Meta", "Apple" },
            "Mobile Devices" => new() { "iPhone 15 Pro Max", "Samsung Galaxy S24", "Pixel 8 Pro", "OnePlus 12" },
            "Technology" => new() { "MacBook Pro", "Dell XPS", "Gaming PC", "iPad Pro" },
            "Services" => new() { "AWS", "Azure", "Google Cloud", "Vercel" },
            "Retail" => new() { "Amazon Prime", "Walmart+", "Best Buy", "Target" },
            "Restaurants" => new() { "Starbucks", "McDonald's", "Pizza Hut", "KFC" },
            "Travel" => new() { "Marriott Hotels", "United Airlines", "Hertz", "Booking.com" },
            _ => new() { "Microsoft", "Apple", "Google", "Amazon", "Tesla", "Netflix" }
        };
    }

    private string GetCategoryIcon(string category)
    {
        return category switch
        {
            "Company Reviews" => "🏢",
            "Mobile Devices" => "📱",
            "Technology" => "💻",
            "Services" => "⚙️",
            "Retail" => "🛒",
            "Restaurants" => "🍽️",
            "Travel" => "✈️",
            _ => "📌"
        };
    }

    private void ShowRequestHelp()
    {
        showRequestHelpModal = true;
    }

    private void CloseRequestHelp()
    {
        showRequestHelpModal = false;
    }
}
